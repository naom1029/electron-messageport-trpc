{
  "name": "electron-messageport-trpc",
  "version": "0.1.1",
  "description": "MessagePort-based tRPC v11 transport for Electron",
  "license": "MIT",
  "author": "naom1029",
  "repository": {
    "type": "git",
    "url": "https://github.com/naom1029/electron-messageport-trpc.git",
    "directory": "packages/electron-messageport-trpc"
  },
  "homepage": "https://github.com/naom1029/electron-messageport-trpc",
  "bugs": {
    "url": "https://github.com/naom1029/electron-messageport-trpc/issues"
  },
  "keywords": [
    "electron",
    "trpc",
    "messageport",
    "ipc",
    "rpc",
    "typescript",
    "type-safe"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "exports": {
    "./main": {
      "import": "./dist/main.mjs",
      "require": "./dist/main.cjs",
      "types": "./dist/main.d.ts"
    },
    "./renderer": {
      "import": "./dist/renderer.mjs",
      "require": "./dist/renderer.cjs",
      "types": "./dist/renderer.d.ts"
    },
    "./preload": {
      "import": "./dist/preload.mjs",
      "require": "./dist/preload.cjs",
      "types": "./dist/preload.d.ts"
    },
    "./utility": {
      "import": "./dist/utility.mjs",
      "require": "./dist/utility.cjs",
      "types": "./dist/utility.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --noEmit && vite build -c src/main/vite.config.ts && vite build -c src/renderer/vite.config.ts && vite build -c src/preload/vite.config.ts && vite build -c src/utility/vite.config.ts",
    "test": "vitest run -c vitest.config.ts",
    "test:watch": "vitest -c vitest.config.ts",
    "test:ci": "vitest run -c vitest.config.ts --coverage"
  },
  "peerDependencies": {
    "@trpc/client": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "electron": ">=22.0.0"
  },
  "devDependencies": {
    "@trpc/client": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "electron": "^41.0.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
