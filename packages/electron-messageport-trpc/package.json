{
  "name": "electron-messageport-trpc",
  "version": "0.4.1",
  "description": "MessagePort-based tRPC v11 transport for Electron",
  "type": "module",
  "license": "MIT",
  "author": "naom1029",
  "repository": {
    "type": "git",
    "url": "https://github.com/naom1029/electron-messageport-trpc.git",
    "directory": "packages/electron-messageport-trpc"
  },
  "homepage": "https://github.com/naom1029/electron-messageport-trpc",
  "bugs": {
    "url": "https://github.com/naom1029/electron-messageport-trpc/issues"
  },
  "keywords": [
    "electron",
    "trpc",
    "messageport",
    "ipc",
    "rpc",
    "typescript",
    "type-safe"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "exports": {
    "./main": {
      "types": "./dist/main/index.d.ts",
      "import": "./dist/main.mjs",
      "default": "./dist/main.mjs"
    },
    "./renderer": {
      "types": "./dist/renderer/index.d.ts",
      "import": "./dist/renderer.mjs",
      "default": "./dist/renderer.mjs"
    },
    "./preload": {
      "types": "./dist/preload/index.d.ts",
      "import": "./dist/preload.mjs",
      "default": "./dist/preload.mjs"
    },
    "./utility": {
      "types": "./dist/utility/index.d.ts",
      "import": "./dist/utility.mjs",
      "default": "./dist/utility.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "typecheck": "tsc --noEmit",
    "build:types": "tsc -p tsconfig.build.json",
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc --noEmit && tsc -p tsconfig.build.json && vite build -c src/main/vite.config.ts && vite build -c src/renderer/vite.config.ts && vite build -c src/preload/vite.config.ts && vite build -c src/utility/vite.config.ts",
    "build:watch": "npm run build:watch:main & npm run build:watch:renderer & npm run build:watch:preload & npm run build:watch:utility & tsc --noEmit --watch --preserveWatchOutput",
    "build:watch:main": "vite build -c src/main/vite.config.ts --watch",
    "build:watch:renderer": "vite build -c src/renderer/vite.config.ts --watch",
    "build:watch:preload": "vite build -c src/preload/vite.config.ts --watch",
    "build:watch:utility": "vite build -c src/utility/vite.config.ts --watch",
    "prepack": "npm run build",
    "test": "vitest run -c vitest.config.ts",
    "test:watch": "vitest -c vitest.config.ts",
    "test:ci": "vitest run -c vitest.config.ts --coverage"
  },
  "peerDependencies": {
    "@trpc/client": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "electron": ">=22.0.0"
  },
  "devDependencies": {
    "@trpc/client": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "@vitest/coverage-v8": "^4.1.0",
    "electron": "^42.2.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.13",
    "vitest": "^4.1.0"
  }
}
